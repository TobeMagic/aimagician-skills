{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aimagician.local/window-pptx/repair-log.v1.schema.json",
  "title": "Window-PPTX Repair Log v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "max_passes", "passes", "changed", "final_report"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "max_passes": {"type": "integer", "minimum": 1, "maximum": 2},
    "passes": {
      "type": "array",
      "maxItems": 2,
      "items": {"$ref": "#/$defs/pass"}
    },
    "changed": {"type": "boolean"},
    "final_report": {"$ref": "#/$defs/report"}
  },
  "$defs": {
    "scalar": {"type": ["string", "number", "boolean", "null"]},
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "target", "values"],
      "properties": {
        "code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "target": {"type": "string", "minLength": 1},
        "values": {"type": "object", "additionalProperties": {"$ref": "#/$defs/scalar"}}
      }
    },
    "pass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "actions", "before_score", "after_score", "accepted", "rolled_back", "hard_gate_failures_before", "hard_gate_failures_after", "failure_code"],
      "properties": {
        "index": {"type": "integer", "minimum": 1, "maximum": 2},
        "actions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/action"}},
        "before_score": {"type": "integer", "minimum": 0},
        "after_score": {"type": "integer", "minimum": 0},
        "accepted": {"type": "boolean"},
        "rolled_back": {"type": "boolean"},
        "hard_gate_failures_before": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "hard_gate_failures_after": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "failure_code": {
          "type": ["string", "null"],
          "pattern": "^[A-Z][A-Z0-9_]+$"
        }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "layers", "findings", "weighted_score", "hard_gate_failures", "passed", "transaction_status"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "layers": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"$ref": "#/$defs/layer"}},
        "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
        "weighted_score": {"type": "integer", "minimum": 0},
        "hard_gate_failures": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "passed": {"type": "boolean"},
        "transaction_status": {"enum": ["pending", "skipped", "promoted", "failed"]}
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "status", "metrics"],
      "properties": {
        "layer": {"enum": ["package", "com", "geometry", "visual", "deck"]},
        "status": {"enum": ["pass", "warn", "fail", "pending", "skipped"]},
        "metrics": {"type": "object", "additionalProperties": {"$ref": "#/$defs/scalar"}}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "layer", "severity", "message", "slide_id", "object_name", "repairable", "details"],
      "properties": {
        "code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "layer": {"enum": ["package", "com", "geometry", "visual", "deck"]},
        "severity": {"enum": ["critical", "error", "warning", "info"]},
        "message": {"type": "string", "minLength": 1},
        "slide_id": {"type": ["string", "null"]},
        "object_name": {"type": ["string", "null"]},
        "repairable": {"type": "boolean"},
        "details": {"type": "object", "additionalProperties": {"$ref": "#/$defs/scalar"}}
      }
    }
  }
}
