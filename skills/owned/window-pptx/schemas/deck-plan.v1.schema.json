{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aimagician.local/window-pptx/deck-plan.v1.schema.json",
  "title": "Window-PPTX DeckPlan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "project": {"$ref": "#/$defs/project"},
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/slide"}
    },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contentBlock"}
    },
    "preferences": {"$ref": "#/$defs/preferences"}
  },
  "oneOf": [
    {"required": ["slides"], "not": {"required": ["content"]}},
    {"required": ["content"], "not": {"required": ["slides"]}}
  ],
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "scenario"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 200, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "scenario": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "audience": {"type": "string", "minLength": 1, "maxLength": 120, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "objective": {"type": "string", "minLength": 1, "maxLength": 300, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "language": {"type": "string", "minLength": 2, "maxLength": 20, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"}
      }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "blocks"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "role": {"$ref": "#/$defs/identifier"},
        "title": {"type": "string", "minLength": 1, "maxLength": 200, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "importance": {"enum": ["low", "normal", "high", "critical"]},
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/contentBlock"}
        }
      }
    },
    "contentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "anyOf": [
        {"required": ["title"]},
        {"required": ["text"]},
        {"required": ["items"]},
        {"required": ["source_ref"]}
      ],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "kind": {
          "enum": ["bullets", "metrics", "comparison", "sequence", "timeline", "trend", "composition", "matrix", "risk", "recommendation", "quote", "table", "image", "statement", "generic"]
        },
        "title": {"type": "string", "minLength": 1, "maxLength": 200, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "text": {"type": "string", "minLength": 1, "maxLength": 4000, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {"type": "string", "minLength": 1, "maxLength": 600, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
              {"type": "number"},
              {"type": "boolean"},
              {"type": "null"},
              {"$ref": "#/$defs/dataItem"}
            ]
          }
        },
        "role_hint": {"$ref": "#/$defs/identifier"},
        "chart_intent": {"enum": ["trend", "comparison", "composition", "distribution", "relationship"]},
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 500, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"}
      }
    },
    "dataItem": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 5,
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "label": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "title": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "name": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "value": {"$ref": "#/$defs/scalar"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 40, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "category": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "series": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "description": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "text": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "status": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "date": {"type": "string", "minLength": 1, "maxLength": 80, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "start": {"$ref": "#/$defs/scalar"},
        "end": {"$ref": "#/$defs/scalar"},
        "source": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "group": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        "primary": {"$ref": "#/$defs/scalar"},
        "secondary": {"$ref": "#/$defs/scalar"},
        "before": {"$ref": "#/$defs/scalar"},
        "after": {"$ref": "#/$defs/scalar"},
        "target": {"$ref": "#/$defs/scalar"},
        "actual": {"$ref": "#/$defs/scalar"},
        "probability": {"$ref": "#/$defs/scalar"},
        "impact": {"$ref": "#/$defs/scalar"},
        "owner": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"}
      }
    },
    "scalar": {
      "anyOf": [
        {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^\\S(?:[\\s\\S]*\\S)?$(?![\\s\\S])"},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "null"}
      ]
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tone": {"enum": ["conservative", "professional", "bold", "editorial", "educational"]},
        "density": {"enum": ["sparse", "balanced", "dense"]},
        "audience_mode": {"enum": ["executive", "customer", "investor", "internal", "learner", "general"]}
      }
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,79}$(?![\\s\\S])"
    }
  }
}
