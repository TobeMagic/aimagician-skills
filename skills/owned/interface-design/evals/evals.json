{
  "schema_version": 1,
  "skill": "interface-design",
  "scenarios": [
    {
      "id": "premium-product-landing",
      "prompt": "Design and implement a premium product launch page in HTML with real product evidence and responsive behavior.",
      "should_trigger": true,
      "expected": ["delivery route", "content and audience brief", "product-first macrostructure", "visual direction", "semantic tokens", "320-to-desktop screenshots", "anti-template critique"],
      "forbidden": ["generic centered hero", "invented metrics", "three identical feature cards", "native pptx workflow"]
    },
    {
      "id": "operational-dashboard",
      "prompt": "Build a dense operations dashboard with trends, filters, exceptions, and repeated record actions.",
      "should_trigger": true,
      "expected": ["decision-first metrics", "command-center or workbench layout", "table and chart semantics", "loading empty error stale states", "keyboard and responsive verification"],
      "forbidden": ["marketing page", "decorative card wall", "unlabeled chart axes", "mobile shrink-only layout"]
    },
    {
      "id": "interactive-app-prototype",
      "prompt": "Create an interactive mobile app prototype to validate onboarding, a primary task, and failure recovery.",
      "should_trigger": true,
      "expected": ["fidelity contract", "screen and transition map", "real simulated placeholder labels", "critical flow", "failure recovery", "target-device verification"],
      "forbidden": ["disconnected screenshots", "undocumented fake production behavior", "decorative device chrome as the main design"]
    },
    {
      "id": "browser-presentation",
      "prompt": "Create an HTML presentation for a product strategy review with interactive evidence and browser full-screen delivery.",
      "should_trigger": true,
      "expected": ["browser-native route", "narrative arc", "varied frame grammar", "stable slide geometry", "keyboard navigation", "per-frame visual QA"],
      "forbidden": ["claim native PowerPoint", "repeat one card layout on every frame", "skip sequence review"]
    },
    {
      "id": "native-powerpoint-boundary",
      "prompt": "Deliver an editable PowerPoint .pptx with a slide master and Office compatibility.",
      "should_trigger": false,
      "expected": ["route to pptx or window-pptx", "native owner controls production and QA"],
      "forbidden": ["generate HTML as final artifact", "claim HTML conversion is equivalent to native PowerPoint"]
    },
    {
      "id": "hybrid-presentation-handoff",
      "prompt": "Explore a presentation visual direction in HTML, then deliver a native editable PowerPoint deck.",
      "should_trigger": true,
      "expected": ["HTML visual exploration", "approved direction", "ppt handoff contract", "native PPT owner", "separate acceptance evidence"],
      "forbidden": ["one owner claims both artifacts without routing", "lossy conversion presented as native reconstruction"]
    },
    {
      "id": "github-readme-cover",
      "prompt": "Design a premium GitHub README cover for this developer tool and integrate current product proof.",
      "should_trigger": true,
      "expected": ["repository truth pass", "audience and positioning", "claim-to-evidence ledger", "materially different directions", "repository-product-hero", "editable source", "static README asset", "full and downscaled QA"],
      "forbidden": ["one-shot image prompt", "generic neon terminal", "invented output", "stale version"]
    },
    {
      "id": "marketing-poster",
      "prompt": "Create a product launch poster from the real product UI and verified brand assets.",
      "should_trigger": true,
      "expected": ["fixed-format visual contract", "campaign-poster", "identity value proof hierarchy", "safe area", "source and rendered still", "thumbnail inspection"],
      "forbidden": ["unverified claim", "dense unreadable copy", "resize one composition blindly across ratios"]
    },
    {
      "id": "product-demo-video",
      "prompt": "Make an eight-second product demo loop for the README with a poster fallback.",
      "should_trigger": true,
      "expected": ["motion storyboard", "demo-story-sequence", "deterministic time setter", "asset readiness", "silent encoded video", "poster fallback", "first middle last frame inspection", "media contract validation"],
      "forbidden": ["wall-clock capture", "autoplay sound", "no static fallback", "claim quality from source inspection"]
    },
    {
      "id": "creative-coding-visual",
      "prompt": "Create an interactive Canvas and SVG visual experiment with deterministic capture.",
      "should_trigger": true,
      "expected": ["primitive selection", "fixed stage geometry", "seeded randomness", "deterministic time", "nonblank pixel check", "reduced motion fallback"],
      "forbidden": ["unseeded capture", "Canvas text that should remain semantic", "blank or unverified output"]
    },
    {
      "id": "readme-autoplay-gif",
      "prompt": "Create a short autoplaying GIF hero for this GitHub README from the existing HTML product demo.",
      "should_trigger": true,
      "expected": ["repository truth", "accepted or three-direction decision", "deterministic HTML source", "gif route", "palette optimization", "infinite loop", "file budget", "relative README path", "representative-frame validation"],
      "forbidden": ["ephemeral attachment URL", "wall-clock recording", "unbounded GIF", "replace product proof with generic image generation"]
    },
    {
      "id": "html-first-editable-pptx",
      "prompt": "Use HTML to create this presentation and export an editable PPTX so my team can edit the text.",
      "should_trigger": true,
      "expected": ["html-first pipeline", "editable mode", "two-slide showcase for five-plus slides", "multi-file HTML deck", "DOM conversion constraints", "native text and shapes", "fail-closed deck export", "PPTX editability verification"],
      "forbidden": ["route directly to ordinary native PPT owner", "image-only slides", "write unrestricted HTML before selecting editability", "partial PPTX delivery"]
    },
    {
      "id": "html-first-fidelity-pptx",
      "prompt": "Build the presentation in HTML with complex SVG and gradients, then package it as a visually identical PPTX; editability is not required.",
      "should_trigger": true,
      "expected": ["html-first pipeline", "fidelity mode", "browser deck source", "verified full-slide images", "non-editability disclosure", "slide-count and geometry validation"],
      "forbidden": ["claim object editability", "remove browser-native effects", "route to native PPT generation"]
    },
    {
      "id": "html-first-pptx-decision",
      "prompt": "Use HTML to make a presentation and convert it to PPTX.",
      "should_trigger": true,
      "expected": ["decision required", "ask editable versus fidelity before implementation", "HTML remains source of truth"],
      "forbidden": ["silently choose a mode", "start producing all slides", "ordinary native PPT routing"]
    },
    {
      "id": "device-prototype-variants",
      "prompt": "Make three directions for this mobile app and let me compare meaningful design tweaks in an interactive device prototype.",
      "should_trigger": true,
      "expected": ["three real direction previews", "comparison canvas", "target device frame", "no more than six meaningful tweaks", "persisted selection", "connected Playwright click path"],
      "forbidden": ["three color-only variants", "decorative device frame dominates", "disconnected screenshots", "hundreds of CSS controls"]
    },
    {
      "id": "narrated-launch-film",
      "prompt": "Create a narrated five-minute HTML animation with TTS, music, sound effects, and an MP4 delivery.",
      "should_trigger": true,
      "expected": ["approved script segments", "provider-neutral TTS adapter", "measured clip timing", "continuous narration stage", "licensed audio cues", "ducked mix", "transcript", "loudness and sync verification"],
      "forbidden": ["hardcoded token", "bundled personal media", "autoplay browser sound", "PowerPoint-like scene cuts", "unlicensed audio"]
    },
    {
      "id": "evidence-infographic",
      "prompt": "Turn these sourced adoption figures and this four-step process into a vertical infographic for a product report.",
      "should_trigger": true,
      "expected": ["infographic route", "evidence-infographic", "source-qualified stat blocks", "annotated diagram", "target-ratio composition", "distribution-size inspection", "text fallback"],
      "forbidden": ["dashboard shell", "unsourced statistics", "decorative area encoding", "blind desktop resize", "card wall"]
    }
  ]
}
